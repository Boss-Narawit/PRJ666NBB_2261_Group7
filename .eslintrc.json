{
  "root": true,
  "extends": ["eslint:recommended", "prettier"],
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", { "ignoreRestSiblings": true }]
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "backend/tests/**/*.js"],
      "env": { "jest": true }
    }
  ]
}
