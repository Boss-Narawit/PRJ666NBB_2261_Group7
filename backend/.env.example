# Copy to backend/.env and fill in real values. Never commit .env.

# Server
PORT=3000

# MongoDB Atlas connection string — ask a teammate for credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app>

# Auth — JWT_SECRET is required (server fails fast without it)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudinary (clothing image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
